{
  "manifest_version": 3,
  "name": "AgentHQ Chrome Bridge",
  "version": "2.0.0",
  "description": "Bridge between AgentHQ and this Chrome session with visible active/inactive status.",
  "permissions": [
    "tabs",
    "scripting",
    "debugger",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AgentHQ Bridge",
    "default_popup": "popup.html"
  }
}
