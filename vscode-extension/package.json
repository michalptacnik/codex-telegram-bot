{
  "name": "agent-hq",
  "displayName": "Agent HQ",
  "description": "VS Code extension for Agent HQ — powered by ZeroClaw engine",
  "version": "1.0.0",
  "publisher": "agent-hq",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Chat"],
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "configuration": {
      "title": "Codex Control Center",
      "properties": {
        "codex-control-center.gatewayUrl": {
          "type": "string",
          "default": "http://127.0.0.1:42617",
          "description": "Base URL of the Codex Control Center gateway"
        },
        "codex-control-center.apiKey": {
          "type": "string",
          "default": "",
          "description": "LOCAL_API_KEYS token for REST API calls"
        },
        "codex-control-center.uiSecret": {
          "type": "string",
          "default": "",
          "description": "CONTROL_CENTER_UI_SECRET for WebSocket authentication"
        },
        "codex-control-center.defaultChatId": {
          "type": "number",
          "default": 1,
          "description": "Default chat_id used when starting a new session over WebSocket."
        },
        "codex-control-center.defaultUserId": {
          "type": "number",
          "default": 1,
          "description": "Default user_id used when starting a new session over WebSocket."
        },
        "codex-control-center.defaultAgentId": {
          "type": "string",
          "default": "default",
          "description": "Default agent_id for chat messages."
        }
      }
    },
    "commands": [
      {
        "command": "codex-cc.askAgent",
        "title": "Codex: Ask Agent"
      },
      {
        "command": "codex-cc.sendSelection",
        "title": "Codex: Send Selection to Agent"
      },
      {
        "command": "codex-cc.reconnect",
        "title": "Codex: Reconnect to Gateway"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codex-cc-sidebar",
          "title": "Codex",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "codex-cc-sidebar": [
        {
          "type": "webview",
          "id": "codex-cc.chatView",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "codex-cc.sendSelection",
          "when": "editorHasSelection",
          "group": "codex"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "mocha": "^10.8.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
